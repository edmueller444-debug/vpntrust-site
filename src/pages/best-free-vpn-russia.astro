---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import Faq from '@/components/Faq.astro';

const vpnList = [
  {
    name: 'Proton VPN',
    speed: 'Высокая',
    devices: 'Без ограничений',
    servers: '3000+',
    price: 'Бесплатно / от $4',
    rating: 5,
    pros: ['Нет лимита трафика', 'Швейцарская компания', 'Подтверждённая политика no-logs'],
    cons: ['Бесплатно только 3 локации', 'В пиковые часы бывают задержки']
  },
  {
    name: 'Windscribe',
    speed: 'Высокая',
    devices: 'Без ограничений',
    servers: '500+',
    price: 'Бесплатно / от $5',
    rating: 4,
    pros: ['10 ГБ ежемесячно', 'Блокировщик рекламы', 'Гибкая система тарифов'],
    cons: ['Трафик ограничен', 'Серверов меньше конкурентов']
  },
  {
    name: 'Hide.me',
    speed: 'Средняя',
    devices: '1 (бесплатно)',
    servers: '2000+',
    price: 'Бесплатно / от $3',
    rating: 4,
    pros: ['10 ГБ без оплаты', 'Поддержка WireGuard', 'Понятный интерфейс'],
    cons: ['Только одно устройство', 'Мало бесплатных локаций']
  },
  {
    name: 'Atlas VPN',
    speed: 'Высокая',
    devices: 'Без ограничений',
    servers: '1000+',
    price: 'Бесплатно / от $2',
    rating: 4,
    pros: ['Подключай сколько хочешь устройств', 'Неплохая скорость', 'Низкая цена'],
    cons: ['Показывает рекламу', 'Ограниченный выбор серверов']
  },
  {
    name: 'PrivadoVPN',
    speed: 'Средняя',
    devices: '1 (бесплатно)',
    servers: '300+',
    price: 'Бесплатно / от $2',
    rating: 3,
    pros: ['10 ГБ без регистрации карты', 'Без навязчивой рекламы', 'Простая настройка'],
    cons: ['Скорость не впечатляет', 'Маленькая сеть серверов']
  }
];

const faqItems = [
  {
    question: 'Кто из бесплатных быстрее всех?',
    answer: 'По нашим тестам — Proton VPN. У них нет искусственного ограничения скорости даже для бесплатных пользователей. Windscribe тоже неплох, но иногда серверы перегружены.'
  },
  {
    question: 'Почему бесплатные сервисы вообще существуют?',
    answer: 'Это маркетинг. Компании дают попробовать продукт бесплатно, чтобы потом вы купили платную версию. Те, кто зарабатывают на рекламе или продаже данных — в наш рейтинг не попадают.'
  },
  {
    question: 'Хватит ли бесплатного для YouTube?',
    answer: 'Proton VPN — да, там нет лимита трафика. Windscribe с его 10 ГБ хватит примерно на 5-7 часов видео в HD. Для постоянного просмотра лучше или платить, или настроить своё решение.'
  },
  {
    question: 'Что делать, если ничего не работает?',
    answer: 'Стандартные протоколы научились блокировать. В этом случае помогают решения с маскировкой трафика — VLESS, Shadowsocks. Это сложнее в настройке, но надёжнее.'
  }
];
---

<BaseLayout 
  title="Рейтинг бесплатных VPN — Что реально работает в 2025" 
  description="Честное сравнение бесплатных VPN-сервисов. Тестируем скорость, проверяем политику конфиденциальности, отмечаем подводные камни."
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Рейтинг сервисов' }]} />
  </div>

  <section class="section">
    <div class="container">
      <h1>Какие бесплатные VPN работают</h1>
      <p class="intro">
        Мы протестировали десятки сервисов и выбрали те, которым можно доверять. 
        Все они имеют прозрачную бизнес-модель и не замечены в продаже пользовательских данных.
      </p>

      <div class="info-box">
        <strong>Имейте в виду:</strong> бесплатные версии всегда чем-то ограничены — 
        трафиком, скоростью или количеством серверов. Для серьёзного использования 
        рассмотрите платные тарифы или собственный сервер.
      </div>

      <h2>Сравнительная таблица</h2>
      <ComparisonTable items={vpnList} />
    </div>
  </section>

  <section class="section details">
    <div class="container">
      <h2>Наши впечатления</h2>
      
      <article class="vpn-review">
        <h3>Proton VPN</h3>
        <p>
          Единственный сервис, который не ставит лимит на трафик даже в бесплатной версии. 
          Компания из Швейцарии, известна по защищённой почте ProtonMail. Проходили независимый 
          аудит безопасности — отчёт в открытом доступе.
        </p>
        <p>
          Из минусов: бесплатно доступны только серверы в трёх странах, и в часы пик 
          они бывают загружены. Но для базовых задач этого хватает.
        </p>
      </article>

      <article class="vpn-review">
        <h3>Windscribe</h3>
        <p>
          Канадский сервис с щедрым бесплатным тарифом — 10 ГБ в месяц. Приятный бонус: 
          встроенный блокировщик рекламы и трекеров. Можно получить дополнительный трафик 
          за активность в соцсетях.
        </p>
        <p>
          Поддерживает WireGuard, что хорошо для скорости. Интерфейс простой и понятный, 
          даже если вы раньше не пользовались подобными программами.
        </p>
      </article>

      <article class="vpn-review">
        <h3>Hide.me</h3>
        <p>
          Малайзийская компания с хорошей репутацией в сообществе. Предлагают 10 ГБ 
          и доступ к серверам в пяти локациях. Из всех бесплатных — один из немногих, 
          кто нормально поддерживает WireGuard.
        </p>
        <p>
          Главное ограничение: только одно устройство. Если нужен VPN и на телефоне, 
          и на компьютере — придётся выбирать или платить.
        </p>
      </article>
    </div>
  </section>

  <section class="section alt-methods">
    <div class="container">
      <h2>Альтернативный путь</h2>
      <p>
        Если готовые сервисы не устраивают по скорости или надёжности, можно поднять 
        собственный сервер. Это требует немного технических знаний, но даёт полный контроль 
        и работает даже при серьёзных блокировках.
      </p>
      <div class="cta-box">
        <a href="/v2raytun" class="btn btn-primary">Как настроить свой сервер</a>
        <a href="/obhod-blokirovok" class="btn btn-outline">Все способы обхода</a>
      </div>
    </div>
  </section>

  <Faq items={faqItems} />
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1rem;
  }
  
  .intro {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 800px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  
  .info-box {
    background: rgba(37, 99, 235, 0.1);
    border-left: 4px solid var(--color-primary);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  
  .info-box strong {
    color: var(--color-primary);
  }
  
  h2 {
    margin-top: 2rem;
    margin-bottom: 1.5rem;
  }
  
  .details {
    background: var(--color-bg-alt);
  }
  
  .vpn-review {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .vpn-review:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  
  .vpn-review h3 {
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }
  
  .vpn-review p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  
  .alt-methods {
    text-align: center;
  }
  
  .alt-methods p {
    max-width: 600px;
    margin: 0 auto 1.5rem;
    color: var(--color-text-light);
  }
  
  .cta-box {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
