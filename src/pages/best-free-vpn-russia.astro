---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import Faq from '@/components/Faq.astro';

const vpnList = [
  {
    name: 'Proton VPN',
    speed: 'Высокая',
    devices: 'Безлимит',
    servers: '3000+',
    price: 'Бесплатно / от $4',
    rating: 5,
    pros: ['Безлимитный трафик', 'Строгая политика no-logs', 'Швейцарская юрисдикция'],
    cons: ['Бесплатная версия медленнее', 'Мало бесплатных серверов']
  },
  {
    name: 'Windscribe',
    speed: 'Высокая',
    devices: 'Безлимит',
    servers: '500+',
    price: 'Бесплатно / от $5',
    rating: 4,
    pros: ['10 ГБ бесплатно в месяц', 'Встроенный блокировщик рекламы', 'Гибкие тарифы'],
    cons: ['Ограниченный бесплатный трафик', 'Меньше серверов']
  },
  {
    name: 'Hide.me',
    speed: 'Средняя',
    devices: '1 (бесплатно)',
    servers: '2000+',
    price: 'Бесплатно / от $3',
    rating: 4,
    pros: ['10 ГБ бесплатно', 'Хорошая скорость', 'Поддержка WireGuard'],
    cons: ['1 устройство бесплатно', 'Ограниченные локации']
  },
  {
    name: 'Atlas VPN',
    speed: 'Высокая',
    devices: 'Безлимит',
    servers: '1000+',
    price: 'Бесплатно / от $2',
    rating: 4,
    pros: ['Безлимит устройств', 'Быстрые серверы', 'Простой интерфейс'],
    cons: ['Реклама в бесплатной версии', 'Мало бесплатных локаций']
  },
  {
    name: 'PrivadoVPN',
    speed: 'Средняя',
    devices: '1 (бесплатно)',
    servers: '300+',
    price: 'Бесплатно / от $2',
    rating: 3,
    pros: ['10 ГБ бесплатно', 'Нет рекламы', 'Простая настройка'],
    cons: ['Ограниченная скорость', 'Мало серверов']
  }
];

const faqItems = [
  {
    question: 'Какой бесплатный VPN самый быстрый?',
    answer: 'Proton VPN и Windscribe показывают лучшие результаты по скорости среди бесплатных VPN. Proton VPN не ограничивает скорость даже в бесплатной версии, но количество серверов ограничено.'
  },
  {
    question: 'Безопасны ли бесплатные VPN?',
    answer: 'Не все. Выбирайте VPN от известных компаний с прозрачной политикой конфиденциальности. Все сервисы в нашем рейтинге проверены и не продают данные пользователей.'
  },
  {
    question: 'Почему бесплатные VPN ограничивают трафик?',
    answer: 'Содержание серверов стоит денег. Бесплатные тарифы — это способ привлечь пользователей к платным версиям. Ограничения помогают компаниям покрывать расходы на инфраструктуру.'
  },
  {
    question: 'Можно ли смотреть YouTube через бесплатный VPN?',
    answer: 'Да, но с ограничениями. Для просмотра видео в HD нужна стабильная скорость. Proton VPN и Windscribe справляются с этой задачей лучше других бесплатных сервисов.'
  },
  {
    question: 'Какой VPN лучше для обхода блокировок в России?',
    answer: 'Рекомендуем VPN с поддержкой современных протоколов (VLESS, WireGuard) и обфускацией трафика. Proton VPN и Windscribe хорошо работают в условиях блокировок.'
  }
];
---

<BaseLayout 
  title="Лучшие бесплатные VPN для России 2025 — Рейтинг работающих VPN" 
  description="Рейтинг лучших бесплатных VPN, которые работают в России. Сравнение Proton VPN, Windscribe, Hide.me и других. Скорость, безопасность, ограничения."
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Лучшие бесплатные VPN' }]} />
  </div>

  <section class="section">
    <div class="container">
      <h1>Лучшие бесплатные VPN для России</h1>
      <p class="intro">
        Собрали проверенные бесплатные VPN-сервисы, которые работают в России. 
        Все сервисы протестированы на скорость, безопасность и стабильность соединения. 
        Рейтинг обновляется регулярно.
      </p>

      <div class="info-box">
        <strong>Важно:</strong> Бесплатные VPN имеют ограничения по трафику или скорости. 
        Для постоянного использования рекомендуем платные тарифы или настройку собственного VPN через V2RayTun.
      </div>

      <h2>Сравнительная таблица VPN</h2>
      <ComparisonTable items={vpnList} />
    </div>
  </section>

  <section class="section details">
    <div class="container">
      <h2>Подробные обзоры</h2>
      
      <article class="vpn-review">
        <h3>Proton VPN — лучший бесплатный VPN</h3>
        <p>
          Proton VPN от создателей ProtonMail — единственный бесплатный VPN без ограничений по трафику. 
          Швейцарская компания с безупречной репутацией в области конфиденциальности. 
          Строгая политика no-logs подтверждена независимым аудитом.
        </p>
        <p>
          Бесплатная версия включает серверы в 3 странах (США, Нидерланды, Япония). 
          Скорость не ограничена, но может снижаться в часы пик из-за высокой нагрузки.
        </p>
      </article>

      <article class="vpn-review">
        <h3>Windscribe — 10 ГБ бесплатно каждый месяц</h3>
        <p>
          Windscribe предлагает 10 ГБ бесплатного трафика ежемесячно — достаточно для базового использования. 
          Встроенный блокировщик рекламы и трекеров. Работает на всех популярных платформах.
        </p>
        <p>
          Поддерживает протокол WireGuard для максимальной скорости. 
          Можно получить дополнительный трафик за твиты и рефералов.
        </p>
      </article>

      <article class="vpn-review">
        <h3>Hide.me — надежный VPN с WireGuard</h3>
        <p>
          Hide.me — малайзийский VPN-сервис с хорошей репутацией. Бесплатный тариф включает 10 ГБ трафика 
          и доступ к серверам в 5 локациях. Поддержка современных протоколов, включая WireGuard.
        </p>
        <p>
          Ограничение — только 1 устройство в бесплатной версии. 
          Подходит для тех, кому нужен VPN только на смартфоне или компьютере.
        </p>
      </article>
    </div>
  </section>

  <section class="section alt-methods">
    <div class="container">
      <h2>Альтернатива: свой VPN-сервер</h2>
      <p>
        Если бесплатные VPN не подходят по скорости или надежности, рассмотрите настройку собственного VPN. 
        Протокол VLESS с маскировкой трафика работает даже при жестких блокировках.
      </p>
      <div class="cta-box">
        <a href="/v2raytun" class="btn btn-primary">Инструкция по V2RayTun</a>
        <a href="/obhod-blokirovok" class="btn btn-outline">Способы обхода блокировок</a>
      </div>
    </div>
  </section>

  <Faq items={faqItems} />
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1rem;
  }
  
  .intro {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 800px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  
  .info-box {
    background: rgba(37, 99, 235, 0.1);
    border-left: 4px solid var(--color-primary);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  
  .info-box strong {
    color: var(--color-primary);
  }
  
  h2 {
    margin-top: 2rem;
    margin-bottom: 1.5rem;
  }
  
  .details {
    background: var(--color-bg-alt);
  }
  
  .vpn-review {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .vpn-review:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  
  .vpn-review h3 {
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }
  
  .vpn-review p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  
  .alt-methods {
    text-align: center;
  }
  
  .alt-methods p {
    max-width: 600px;
    margin: 0 auto 1.5rem;
    color: var(--color-text-light);
  }
  
  .cta-box {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
