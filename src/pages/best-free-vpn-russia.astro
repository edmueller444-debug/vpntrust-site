---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ComparisonTable from '@/components/ComparisonTable.astro';
import Faq from '@/components/Faq.astro';

const vpnList = [
  {
    name: 'Ops VPN',
    speed: 'Высокая',
    devices: 'Без ограничений',
    servers: '50+',
    price: 'Бесплатно',
    rating: 5,
    pros: ['Работает через Telegram-бот', 'Простая активация', 'Стабильное соединение'],
    cons: ['Ограниченное количество локаций', 'Только через Telegram'],
    link: 'https://t.me/opsvpnbot'
  },
  {
    name: 'Durev VPN',
    speed: 'Высокая',
    devices: 'Без ограничений',
    servers: '30+',
    price: 'Бесплатно',
    rating: 4,
    pros: ['Telegram-бот для управления', 'Быстрое подключение', 'Без регистрации'],
    cons: ['Меньше серверов', 'Периодические обновления'],
    link: 'https://t.me/durevvpn'
  },
  {
    name: 'DedVPN',
    speed: 'Высокая',
    devices: 'До 5',
    servers: '100+',
    price: 'Бесплатно / Premium',
    rating: 4,
    pros: ['Много серверов', 'Веб-интерфейс', 'Поддержка разных протоколов'],
    cons: ['Требуется регистрация', 'Premium для всех функций'],
    link: 'https://dedmax.com/'
  },
  {
    name: 'Sota VPN',
    speed: 'Средняя',
    devices: 'До 3',
    servers: '40+',
    price: 'Бесплатно / Premium',
    rating: 4,
    pros: ['Простой интерфейс', 'Работает стабильно', 'Есть мобильные приложения'],
    cons: ['Ограничения в бесплатной версии', 'Реклама'],
    link: 'https://sotavpn.net/'
  }
];

const faqItems = [
  {
    question: 'Какой из этих VPN самый быстрый?',
    answer: 'По нашим тестам Ops VPN и DedVPN показывают лучшую скорость. Ops VPN особенно хорош благодаря оптимизированным серверам и простой архитектуре через Telegram.'
  },
  {
    question: 'Безопасно ли использовать бесплатные VPN?',
    answer: 'Перечисленные сервисы имеют хорошую репутацию в сообществе. Они зарабатывают на premium-подписках, а не на продаже данных. Для дополнительной безопасности рекомендуем настроить собственный сервер.'
  },
  {
    question: 'Почему VPN работает через Telegram?',
    answer: 'Telegram-боты удобны для распространения конфигураций и управления подключениями. Они не блокируются так легко, как сайты, и позволяют быстро получить рабочую конфигурацию.'
  },
  {
    question: 'Что делать, если VPN перестал работать?',
    answer: 'Попробуйте обновить конфигурацию через бот или сайт сервиса. Если не помогает — переключитесь на другой сервис из списка или настройте VLESS на собственном сервере.'
  }
];
---

<BaseLayout 
  title="Лучшие бесплатные VPN для России 2025 — Рейтинг и сравнение" 
  description="Рейтинг бесплатных VPN-сервисов для России. Ops VPN, Durev VPN, DedVPN, Sota VPN — сравнение скорости, надёжности и удобства использования."
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Лучшие бесплатные VPN' }]} />
  </div>

  <section class="section">
    <div class="container">
      <h1>Лучшие бесплатные VPN</h1>
      <p class="intro">
        Отобрали сервисы, которые реально работают в текущих условиях. 
        Все протестированы, имеют понятную модель работы и не замечены в сомнительных практиках.
      </p>

      <div class="info-box">
        <strong>Обратите внимание:</strong> бесплатные версии могут иметь ограничения. 
        Для стабильной работы рекомендуем premium-тарифы или собственный сервер с VLESS.
      </div>

      <h2>Сравнительная таблица</h2>
      <ComparisonTable items={vpnList} />
    </div>
  </section>

  <section class="section details">
    <div class="container">
      <h2>Подробнее о каждом сервисе</h2>
      
      <article class="vpn-review">
        <div class="vpn-header">
          <h3>1. Ops VPN</h3>
          <a href="https://t.me/opsvpnbot" class="btn btn-primary" target="_blank" rel="noopener">Скачать VPN</a>
        </div>
        <p>
          Работает через Telegram-бот, что удобно — не нужно устанавливать отдельное приложение для получения конфигурации.
          Запускаете бот, получаете ключ, импортируете в любой клиент. Скорость хорошая, соединение стабильное.
        </p>
        <p>
          Из плюсов: простота использования и отсутствие сложной регистрации. Минус — ограниченный выбор локаций,
          но для большинства задач этого достаточно.
        </p>
      </article>

      <article class="vpn-review">
        <div class="vpn-header">
          <h3>2. Durev VPN</h3>
          <a href="https://t.me/durevvpn" class="btn btn-primary" target="_blank" rel="noopener">Скачать VPN</a>
        </div>
        <p>
          Ещё один сервис с управлением через Telegram. Название намекает на создателя мессенджера, 
          хотя официальной связи нет. Работает быстро, подключение занимает секунды.
        </p>
        <p>
          Серверов меньше, чем у конкурентов, но качество соединения на уровне. Хороший выбор как 
          резервный вариант или для тех, кому нравится минимализм.
        </p>
      </article>

      <article class="vpn-review">
        <div class="vpn-header">
          <h3>3. DedVPN</h3>
          <a href="https://dedmax.com/" class="btn btn-primary" target="_blank" rel="noopener">Скачать VPN</a>
        </div>
        <p>
          Полноценный сервис с веб-интерфейсом и большим выбором серверов. Поддерживает разные протоколы,
          включая современные варианты с маскировкой трафика.
        </p>
        <p>
          Требует регистрации, что не всем нравится. Зато есть личный кабинет, статистика использования 
          и возможность переключаться между серверами без переподключения.
        </p>
      </article>

      <article class="vpn-review">
        <div class="vpn-header">
          <h3>4. Sota VPN</h3>
          <a href="https://sotavpn.net/" class="btn btn-primary" target="_blank" rel="noopener">Скачать VPN</a>
        </div>
        <p>
          Сервис с собственными мобильными приложениями. Интерфейс простой, разобраться легко даже 
          без опыта. Работает стабильно, хотя скорость чуть ниже лидеров.
        </p>
        <p>
          В бесплатной версии есть реклама и ограничения по трафику. Premium снимает эти ограничения
          за небольшую плату.
        </p>
      </article>
    </div>
  </section>

  <section class="section alt-methods">
    <div class="container">
      <h2>Альтернативный путь</h2>
      <p>
        Если готовые сервисы не устраивают по скорости или надёжности, можно поднять 
        собственный сервер. Это требует немного технических знаний, но даёт полный контроль 
        и работает даже при серьёзных блокировках.
      </p>
      <div class="cta-box">
        <a href="/v2raytun" class="btn btn-primary">Как настроить свой сервер</a>
        <a href="/obhod-blokirovok" class="btn btn-outline">Обход белых списков</a>
      </div>
    </div>
  </section>

  <Faq items={faqItems} />
</BaseLayout>

<style>
  h1 {
    margin-bottom: 1rem;
  }
  
  .intro {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 800px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  
  .info-box {
    background: rgba(37, 99, 235, 0.1);
    border-left: 4px solid var(--color-primary);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    border-radius: 0 0.5rem 0.5rem 0;
  }
  
  .info-box strong {
    color: var(--color-primary);
  }
  
  h2 {
    margin-top: 2rem;
    margin-bottom: 1.5rem;
  }
  
  .details {
    background: var(--color-bg-alt);
  }
  
  .vpn-review {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .vpn-review:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  
  .vpn-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  
  .vpn-review h3 {
    color: var(--color-primary);
    margin: 0;
  }
  
  .vpn-review p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  
  .alt-methods {
    text-align: center;
  }
  
  .alt-methods p {
    max-width: 600px;
    margin: 0 auto 1.5rem;
    color: var(--color-text-light);
  }
  
  .cta-box {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
