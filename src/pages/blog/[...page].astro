---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const POSTS_PER_PAGE = 6;

  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  return paginate(posts, {
    pageSize: POSTS_PER_PAGE,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const siteUrl = 'https://vpntrust.site';
const canonical =
  page.currentPage === 1
    ? `${siteUrl}/blog/`
    : `${siteUrl}/blog/${page.currentPage}/`;

const pageTitle =
  page.currentPage === 1
    ? 'Блог VPNTrust — VPN, обход блокировок, безопасность'
    : `Блог VPNTrust — страница ${page.currentPage}`;

const pageDescription =
  page.currentPage === 1
    ? 'Гайды по VPN, обходу блокировок и защите данных. Настройки, сравнения и реальные решения без воды.'
    : `Страница ${page.currentPage} блога VPNTrust: статьи о VPN, безопасности и обходе блокировок.`;

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'VPNTrust Blog',
  description:
    'Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.',
  url: `${siteUrl}/blog/`,
  inLanguage: 'ru-RU',
  publisher: {
    '@type': 'Organization',
    name: 'VPNTrust',
    url: siteUrl,
  },
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  url: canonical,
  isPartOf: {
    '@type': 'Blog',
    name: 'VPNTrust Blog',
    url: `${siteUrl}/blog/`,
  },
  inLanguage: 'ru-RU',
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  noindex={page.currentPage > 1}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(blogSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(collectionPageSchema)}
    />
  </Fragment>

  <main class="blog-page">
    <section class="section blog-hero">
      <div class="container">
        <Breadcrumbs items={[{ label: 'Блог' }]} />

        <div class="blog-hero__content">
          <h1>
            {page.currentPage === 1
              ? 'Блог VPN и обход блокировок'
              : `Блог VPN — страница ${page.currentPage}`}
          </h1>

          <p class="blog-hero__description">
            Статьи о VPN, обходе блокировок и защите конфиденциальности.
            Практические инструкции, честные обзоры и рабочие решения.
          </p>
        </div>
      </div>
    </section>

    <section class="section blog-list-section">
      <div class="container">
        <div class="blog-grid">
          {page.data.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              date={post.data.pubDate.toISOString()}
              category={post.data.category}
            />
          ))}
        </div>

        {page.lastPage > 1 && (
          <nav class="blog-pagination" aria-label="Пагинация блога">
            {page.url.prev && (
              <a href={page.url.prev} class="blog-pagination__nav">
                ← Назад
              </a>
            )}

            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNumber) => {
              const href = pageNumber === 1 ? '/blog/' : `/blog/${pageNumber}/`;
              const isActive = pageNumber === page.currentPage;

              return (
                <a
                  href={href}
                  class:list={['blog-pagination__item', isActive && 'is-active']}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {pageNumber}
                </a>
              );
            })}

            {page.url.next && (
              <a href={page.url.next} class="blog-pagination__nav">
                Вперёд →
              </a>
            )}
          </nav>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="blog-cta">
          <div class="blog-cta__content">
            <span class="blog-cta__badge">Нужна помощь</span>
            <h2>Не нашли ответ?</h2>
            <p>
              Посмотрите наши подробные руководства по VPN для разных устройств и
              сценариев.
            </p>
          </div>

          <div class="blog-cta__actions">
            <a href="/best-free-vpn-russia" class="btn btn-primary blog-cta__btn">
              Рейтинг VPN
            </a>
            <a href="/v2raytun" class="btn btn-outline blog-cta__btn">
              Настройка V2RayTun
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-page {
    background:
      radial-gradient(circle at top, rgba(37, 99, 235, 0.05), transparent 28%),
      #fff;
  }

  .blog-hero {
    padding-bottom: 1.5rem;
  }

  .blog-hero__content {
    max-width: 760px;
    margin-top: 1rem;
  }

  .blog-hero__description {
    margin-top: 1rem;
    max-width: 680px;
    font-size: 1.05rem;
    color: var(--color-text-light);
  }

  .blog-list-section {
    padding-top: 1rem;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .blog-pagination {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  .blog-pagination__item,
  .blog-pagination__nav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 0.95rem;
    border-radius: 0.85rem;
    border: 1px solid var(--color-border);
    background: #fff;
    color: var(--color-text);
    font-weight: 600;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease,
      background 0.2s ease;
  }

  .blog-pagination__item:hover,
  .blog-pagination__nav:hover {
    transform: translateY(-2px);
    border-color: rgba(37, 99, 235, 0.25);
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.08);
    color: var(--color-primary);
  }

  .blog-pagination__item.is-active {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    border-color: var(--color-primary);
    color: #fff;
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.18);
  }

  .blog-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2rem;
    border: 1px solid rgba(37, 99, 235, 0.14);
    border-radius: 1.5rem;
    background:
      linear-gradient(135deg, rgba(37, 99, 235, 0.1), rgba(37, 99, 235, 0.03)),
      #f8fbff;
    box-shadow: 0 18px 40px rgba(37, 99, 235, 0.08);
    margin-top: 1rem;
  }

  .blog-cta__content {
    max-width: 720px;
  }

  .blog-cta__badge {
    display: inline-flex;
    margin-bottom: 0.9rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.12);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .blog-cta h2 {
    margin-bottom: 0.75rem;
  }

  .blog-cta p {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .blog-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    flex-shrink: 0;
  }

  .blog-cta__btn {
    min-height: 48px;
    border-radius: 0.875rem;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }

    .blog-cta {
      flex-direction: column;
      align-items: flex-start;
    }

    .blog-cta__actions {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .blog-grid {
      gap: 1rem;
    }

    .blog-pagination {
      margin-top: 2rem;
      gap: 0.5rem;
    }

    .blog-cta {
      padding: 1.35rem;
      border-radius: 1.1rem;
    }

    .blog-cta__actions {
      flex-direction: column;
      width: 100%;
    }

    .blog-cta__btn {
      width: 100%;
    }
  }
</style>
