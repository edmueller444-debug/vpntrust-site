---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  
  return paginate(posts, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout
  title={page.currentPage === 1 ? 'Блог VPNTrust' : `Блог VPNTrust — Страница ${page.currentPage}`}
  description="Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры."
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Блог' }]} />

      <div class="section-heading">
        <h1 class="mb-3">Блог VPNTrust</h1>
        <p class="text-light">
          Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.
        </p>
      </div>

      <div class="blog-grid">
        {page.data.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            date={post.data.pubDate.toISOString()}
            category={post.data.category}
          />
        ))}
      </div>

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Навигация по страницам">
          <a 
            href={page.url.prev || '#'} 
            class={`pagination-btn ${!page.url.prev ? 'disabled' : ''}`}
            aria-disabled={!page.url.prev}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            Назад
          </a>
          
          <div class="pagination-pages">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNum) => (
              <a
                href={pageNum === 1 ? '/blog/' : `/blog/${pageNum}/`}
                class={`pagination-page ${pageNum === page.currentPage ? 'active' : ''}`}
                aria-current={pageNum === page.currentPage ? 'page' : undefined}
              >
                {pageNum}
              </a>
            ))}
          </div>

          <a 
            href={page.url.next || '#'} 
            class={`pagination-btn ${!page.url.next ? 'disabled' : ''}`}
            aria-disabled={!page.url.next}
          >
            Вперёд
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        </nav>
      )}

      <div class="cta-box mt-5">
        <h2>Не нашли ответ?</h2>
        <p>Посмотрите наши подробные руководства по VPN для разных устройств и сценариев</p>
        <div class="hero__actions">
          <a href="/best-free-vpn-russia/" class="btn btn-primary">Рейтинг VPN</a>
          <a href="/v2raytun/" class="btn btn-outline">Настройка V2RayTun</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    gap: 1.5rem;
  }

  .mt-5 {
    margin-top: 3rem;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .pagination-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .pagination-btn:hover:not(.disabled) {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .pagination-btn.disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .pagination-page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    transition: all 0.2s;
  }

  .pagination-page:hover:not(.active) {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .pagination-page.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .cta-box {
    background: #0f172a;
    color: #fff;
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .cta-box h2 {
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cta-box p {
    color: #cbd5e1;
    margin-bottom: 1.25rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
    }

    .pagination {
      gap: 0.375rem;
    }

    .pagination-btn {
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
    }

    .pagination-page {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 0.875rem;
    }
  }
</style>
