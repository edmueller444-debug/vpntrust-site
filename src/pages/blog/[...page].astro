---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 6;

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  return paginate(posts, {
    pageSize: POSTS_PER_PAGE,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const pageTitle =
  page.currentPage === 1
    ? 'Блог VPNTrust'
    : `Блог VPNTrust — страница ${page.currentPage}`;

const pageDescription =
  'Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://vpntrust.ru${page.url.current}`}
>
  <section class="container mx-auto px-4 py-10">
    <Breadcrumbs
      items={[
        { label: 'Главная', href: '/' },
        { label: 'Блог', href: '/blog/' },
      ]}
    />

    <div class="mt-6 mb-10">
      <h1 class="text-3xl md:text-4xl font-bold">
        {page.currentPage === 1 ? 'Блог VPNTrust' : `Блог VPNTrust — страница ${page.currentPage}`}
      </h1>
      <p class="mt-3 text-muted-foreground max-w-3xl">
        Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          slug={post.slug}
          date={post.data.pubDate.toISOString()}
          category={post.data.category}
        />
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="mt-10 flex flex-wrap items-center justify-center gap-2" aria-label="Пагинация блога">
        {page.url.prev && (
          <a
            href={page.url.prev}
            class="inline-flex h-10 items-center justify-center rounded-lg border px-4 text-sm transition hover:bg-muted"
          >
            ← Назад
          </a>
        )}

        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNumber) => {
          const href = pageNumber === 1 ? '/blog/' : `/blog/${pageNumber}/`;

          return (
            <a
              href={href}
              class:list={[
                'inline-flex h-10 min-w-10 items-center justify-center rounded-lg border px-4 text-sm transition',
                pageNumber === page.currentPage
                  ? 'bg-primary text-primary-foreground border-primary'
                  : 'hover:bg-muted',
              ]}
              aria-current={pageNumber === page.currentPage ? 'page' : undefined}
            >
              {pageNumber}
            </a>
          );
        })}

        {page.url.next && (
          <a
            href={page.url.next}
            class="inline-flex h-10 items-center justify-center rounded-lg border px-4 text-sm transition hover:bg-muted"
          >
            Вперёд →
          </a>
        )}
      </nav>
    )}

    <div class="mt-14 rounded-2xl border p-6 md:p-8">
      <h2 class="text-2xl font-semibold">Не нашли ответ?</h2>
      <p class="mt-3 text-muted-foreground">
        Посмотрите наши подробные руководства по VPN для разных устройств и сценариев
      </p>

      <div class="mt-5 flex flex-wrap gap-3">
        <a
          href="/best-free-vpn-russia/"
          class="inline-flex items-center rounded-lg border px-4 py-2 text-sm transition hover:bg-muted"
        >
          Рейтинг VPN
        </a>

        <a
          href="/v2raytun/"
          class="inline-flex items-center rounded-lg border px-4 py-2 text-sm transition hover:bg-muted"
        >
          Настройка V2RayTun
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
