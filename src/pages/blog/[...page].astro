---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const POSTS_PER_PAGE = 6;

  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );

  return paginate(posts, {
    pageSize: POSTS_PER_PAGE,
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const pageTitle =
  page.currentPage === 1
    ? 'Блог VPNTrust'
    : `Блог VPNTrust — страница ${page.currentPage}`;

const pageDescription =
  'Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`https://vpntrust.ru${page.url.current}`}
>
  <section class="container mx-auto px-4 py-10">
    <Breadcrumbs
      items={[
        { label: 'Главная', href: '/' },
        { label: 'Блог', href: '/blog/' },
      ]}
    />

    <div class="mt-6 mb-10">
      <h1 class="text-3xl md:text-4xl font-bold">
        {page.currentPage === 1 ? 'Блог VPNTrust' : `Блог VPNTrust — страница ${page.currentPage}`}
      </h1>
      <p class="mt-3 text-muted-foreground max-w-3xl">
        Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          slug={post.slug}
          date={post.data.pubDate.toISOString()}
          category={post.data.category}
        />
      ))}
    </div>

    {page.lastPage > 1 && (
      <div class="mt-10 mb-16">
        <nav
          class="flex flex-wrap items-center justify-center gap-3"
          aria-label="Пагинация блога"
        >
          {page.url.prev && (
            <a
              href={page.url.prev}
              class="inline-flex h-10 items-center justify-center rounded-lg border px-4 text-sm font-medium transition hover:bg-muted"
            >
              ← Назад
            </a>
          )}

          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((pageNumber) => {
            const href = pageNumber === 1 ? '/blog/' : `/blog/${pageNumber}/`;
            const isActive = pageNumber === page.currentPage;

            return (
              <a
                href={href}
                class:list={[
                  'inline-flex h-10 min-w-10 items-center justify-center rounded-lg border px-4 text-sm font-medium transition',
                  isActive
                    ? 'border-primary bg-primary text-primary-foreground'
                    : 'hover:bg-muted',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {pageNumber}
              </a>
            );
          })}

          {page.url.next && (
            <a
              href={page.url.next}
              class="inline-flex h-10 items-center justify-center rounded-lg border px-4 text-sm font-medium transition hover:bg-muted"
            >
              Вперёд →
            </a>
          )}
        </nav>
      </div>
    )}

    <div class="mt-16 rounded-2xl border bg-card p-6 shadow-sm md:p-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold md:text-3xl">Не нашли ответ?</h2>
        <p class="mt-3 text-base text-muted-foreground md:text-lg">
          Посмотрите наши подробные руководства по VPN для разных устройств и сценариев.
        </p>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="/best-free-vpn-russia/"
          class="inline-flex items-center rounded-lg border px-4 py-2.5 text-sm font-medium transition hover:bg-muted"
        >
          Рейтинг VPN
        </a>

        <a
          href="/v2raytun/"
          class="inline-flex items-center rounded-lg border px-4 py-2.5 text-sm font-medium transition hover:bg-muted"
        >
          Настройка V2RayTun
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
