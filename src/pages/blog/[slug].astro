---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('blog');

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404/');
}

const post = allPosts.find((item) => item.slug === slug);

if (!post) {
  return Astro.redirect('/404/');
}

const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const relatedPosts = allPosts
  .filter((item) => item.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const siteUrl = 'https://vpntrust.site';
const canonical = `${siteUrl}/blog/${post.slug}/`;
const title = `${post.data.title} — VPNTrust`;
const description = post.data.description;
const faqItems = post.data.faq ?? [];
const tocItems = [
  ...headings.filter((heading) => heading.depth === 2),
  ...(faqItems.length > 0
    ? [
        {
          depth: 2,
          slug: 'faq-title',
          text: 'Частые вопросы',
        },
      ]
    : []),
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && {
    dateModified: post.data.updatedDate.toISOString(),
  }),
  mainEntityOfPage: canonical,
  inLanguage: 'ru-RU',
  author: {
    '@type': 'Organization',
    name: 'VPNTrust',
  },
  publisher: {
    '@type': 'Organization',
    name: 'VPNTrust',
    url: siteUrl,
  },
  ...(post.data.heroImage && {
    image: [`${siteUrl}${post.data.heroImage}`],
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Главная',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Блог',
      item: `${siteUrl}/blog/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: canonical,
    },
  ],
};

const faqSchema =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={post.data.heroImage}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
    {faqSchema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(faqSchema)}
      />
    )}
  </Fragment>

  <main class="blog-post-page">
    <section class="section blog-post-hero">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: 'Блог', href: '/blog/' },
            { label: post.data.title },
          ]}
        />

        <div class="blog-post-hero__meta">
          <span class="blog-post-hero__category">{post.data.category}</span>
          <span class="blog-post-hero__dot">•</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        </div>

        <p class="blog-post-hero__title">{post.data.title}</p>
        <p class="blog-post-hero__description">{post.data.description}</p>
      </div>
    </section>

    <section class="section blog-post-content-section">
      <div class="container blog-post-layout">
        {tocItems.length > 1 && (
          <aside class="blog-post-toc" aria-label="Оглавление статьи">
            <div class="blog-post-toc__inner">
              <h2>Содержание</h2>
              <ul>
                {tocItems.map((item) => (
                  <li>
                    <a href={`#${item.slug}`}>{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}

        <article class="blog-post-content">
          {post.data.heroImage && (
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="blog-post-content__image"
              loading="eager"
            />
          )}

          <Content />

          {faqItems.length > 0 && (
            <section class="blog-post-faq" aria-labelledby="faq-title">
              <h2 id="faq-title">Частые вопросы</h2>

              <div class="blog-post-faq__list">
                {faqItems.map((item) => (
                  <details class="blog-post-faq__item">
                    <summary>{item.question}</summary>
                    <p>{item.answer}</p>
                  </details>
                ))}
              </div>
            </section>
          )}
        </article>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="section related-posts-section">
        <div class="container">
          <div class="related-posts__header">
            <h2>Читайте также</h2>
            <p>Ещё материалы по VPN, безопасности и обходу блокировок.</p>
          </div>

          <div class="related-posts__grid">
            {relatedPosts.map((relatedPost) => (
              <BlogCard
                title={relatedPost.data.title}
                description={relatedPost.data.description}
                slug={relatedPost.slug}
                date={relatedPost.data.pubDate.toISOString()}
                category={relatedPost.data.category}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .blog-post-page {
    overflow-x: hidden;
  }

  .blog-post-hero {
    padding-bottom: 0.5rem;
  }

  .blog-post-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .blog-post-hero__category {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.08);
    color: var(--color-primary);
    font-weight: 600;
    line-height: 1;
  }

  .blog-post-hero__dot {
    opacity: 0.5;
  }

  .blog-post-hero__title {
    max-width: 900px;
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.12;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .blog-post-hero__description {
    max-width: 760px;
    font-size: 1.05rem;
    color: var(--color-text-light);
  }

  .blog-post-layout {
    display: grid;
    grid-template-columns: minmax(0, 280px) minmax(0, 760px);
    gap: 2rem;
    align-items: start;
  }

  .blog-post-toc {
    position: sticky;
    top: 88px;
  }

  .blog-post-toc__inner {
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .blog-post-toc__inner h2 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-toc__inner ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-post-toc__inner li + li {
    margin-top: 0.55rem;
  }

  .blog-post-toc__inner a {
    color: var(--color-text-light);
    line-height: 1.45;
  }

  .blog-post-toc__inner a:hover {
    color: var(--color-primary);
  }

  .blog-post-content {
    min-width: 0;
  }

  .blog-post-content :global(h1:first-child) {
    display: none;
  }

  .blog-post-content__image {
    width: 100%;
    border-radius: 1rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .blog-post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-content :global(p),
  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin-bottom: 1rem;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    padding-left: 1.25rem;
  }

  .blog-post-content :global(li + li) {
    margin-top: 0.5rem;
  }

  .blog-post-content :global(hr) {
    margin: 2rem 0;
    border: 0;
    border-top: 1px solid var(--color-border);
  }

  .blog-post-faq {
    margin-top: 3rem;
    padding-top: 0.5rem;
  }

  .blog-post-faq__list {
    display: grid;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .blog-post-faq__item {
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: #fff;
    padding: 1rem;
  }

  .blog-post-faq__item summary {
    cursor: pointer;
    list-style: none;
    font-weight: 600;
    line-height: 1.5;
  }

  .blog-post-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .blog-post-faq__item p {
    margin: 0.85rem 0 0;
    color: var(--color-text-light);
  }

  .related-posts-section {
    padding-top: 1rem;
  }

  .related-posts__header {
    margin-bottom: 1.5rem;
  }

  .related-posts__header p {
    margin-top: 0.5rem;
    color: var(--color-text-light);
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .blog-post-layout {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .blog-post-toc {
      position: static;
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .blog-post-hero__meta {
      margin-top: 0.5rem;
      margin-bottom: 0.85rem;
      font-size: 0.88rem;
    }

    .blog-post-hero__title {
      font-size: 2rem;
      line-height: 1.15;
      margin-bottom: 0.75rem;
    }

    .blog-post-hero__description {
      font-size: 1rem;
      line-height: 1.65;
    }

    .blog-post-content-section {
      padding-top: 1.25rem;
    }

    .blog-post-toc__inner {
      padding: 0.9rem;
      border-radius: 0.9rem;
    }

    .blog-post-toc__inner a {
      font-size: 0.98rem;
    }

    .blog-post-content__image {
      margin-bottom: 1rem;
      border-radius: 0.9rem;
    }

    .blog-post-content :global(p),
    .blog-post-content :global(ul),
    .blog-post-content :global(ol) {
      font-size: 1rem;
      line-height: 1.75;
    }

    .blog-post-content :global(h2) {
      margin-top: 2rem;
      margin-bottom: 0.85rem;
      font-size: 1.5rem;
      line-height: 1.25;
    }

    .blog-post-content :global(h3) {
      margin-top: 1.25rem;
      margin-bottom: 0.65rem;
      font-size: 1.18rem;
      line-height: 1.35;
    }

    .blog-post-faq {
      margin-top: 2.25rem;
    }

    .blog-post-faq__item {
      border-radius: 0.9rem;
      padding: 0.95rem;
    }

    .related-posts__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
