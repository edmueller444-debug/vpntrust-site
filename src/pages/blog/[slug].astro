---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection, render } from 'astro:content';

const allPosts = await getCollection('blog');

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404/');
}

const post = allPosts.find((item) => item.slug === slug);

if (!post) {
  return Astro.redirect('/404/');
}

const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('ru-RU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const relatedPosts = allPosts
  .filter((item) => item.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const siteUrl = 'https://vpntrust.site';
const canonical = `${siteUrl}/blog/${post.slug}/`;
const title = `${post.data.title} — VPNTrust`;
const description = post.data.description;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && {
    dateModified: post.data.updatedDate.toISOString(),
  }),
  mainEntityOfPage: canonical,
  inLanguage: 'ru-RU',
  author: {
    '@type': 'Organization',
    name: 'VPNTrust',
  },
  publisher: {
    '@type': 'Organization',
    name: 'VPNTrust',
    url: siteUrl,
  },
  ...(post.data.heroImage && {
    image: [`${siteUrl}${post.data.heroImage}`],
  }),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Главная',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Блог',
      item: `${siteUrl}/blog/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: canonical,
    },
  ],
};

const tocItems = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={post.data.heroImage}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(articleSchema)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbSchema)}
    />
  </Fragment>

  <main class="blog-post-page">
    <section class="section blog-post-hero">
      <div class="container">
        <Breadcrumbs
          items={[
            { label: 'Блог', href: '/blog/' },
            { label: post.data.title },
          ]}
        />

        <div class="blog-post-hero__meta">
          <span class="blog-post-hero__category">{post.data.category}</span>
          <span class="blog-post-hero__dot">•</span>
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
        </div>

        <h1 class="blog-post-hero__title">{post.data.title}</h1>
        <p class="blog-post-hero__description">{post.data.description}</p>
      </div>
    </section>

    <section class="section blog-post-content-section">
      <div class="container blog-post-layout">
        <article class="blog-post-content">
          {post.data.heroImage && (
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="blog-post-content__image"
              loading="eager"
            />
          )}

          <Content />
        </article>

        {tocItems.length > 1 && (
          <aside class="blog-post-toc" aria-label="Оглавление статьи">
            <div class="blog-post-toc__inner">
              <h2>Содержание</h2>
              <ul>
                {tocItems.map((item) => (
                  <li>
                    <a href={`#${item.slug}`}>{item.text}</a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="section related-posts-section">
        <div class="container">
          <div class="related-posts__header">
            <h2>Читайте также</h2>
            <p>Ещё материалы по VPN, безопасности и обходу блокировок.</p>
          </div>

          <div class="related-posts__grid">
            {relatedPosts.map((relatedPost) => (
              <BlogCard
                title={relatedPost.data.title}
                description={relatedPost.data.description}
                slug={relatedPost.slug}
                date={relatedPost.data.pubDate.toISOString()}
                category={relatedPost.data.category}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .blog-post-hero {
    padding-bottom: 1rem;
  }

  .blog-post-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  .blog-post-hero__category {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.08);
    color: var(--color-primary);
    font-weight: 600;
    line-height: 1;
  }

  .blog-post-hero__dot {
    opacity: 0.5;
  }

  .blog-post-hero__title {
    max-width: 900px;
    margin-bottom: 1rem;
  }

  .blog-post-hero__description {
    max-width: 760px;
    font-size: 1.05rem;
    color: var(--color-text-light);
  }

  .blog-post-layout {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(240px, 300px);
    gap: 2rem;
    align-items: start;
  }

  .blog-post-content {
    min-width: 0;
  }

  .blog-post-content__image {
    width: 100%;
    border-radius: 1rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border);
  }

  .blog-post-content :global(h2) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-post-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-content :global(p),
  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    padding-left: 1.25rem;
  }

  .blog-post-content :global(li + li) {
    margin-top: 0.5rem;
  }

  .blog-post-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid var(--color-primary);
    background: var(--color-bg-alt);
    border-radius: 0.75rem;
  }

  .blog-post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }

  .blog-post-content :global(th),
  .blog-post-content :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.75rem;
    text-align: left;
  }

  .blog-post-content :global(th) {
    background: var(--color-bg-alt);
  }

  .blog-post-toc {
    position: sticky;
    top: 88px;
  }

  .blog-post-toc__inner {
    padding: 1rem 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
  }

  .blog-post-toc__inner h2 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-toc__inner ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-post-toc__inner li + li {
    margin-top: 0.55rem;
  }

  .blog-post-toc__inner a {
    color: var(--color-text-light);
  }

  .blog-post-toc__inner a:hover {
    color: var(--color-primary);
  }

  .related-posts-section {
    padding-top: 1rem;
  }

  .related-posts__header {
    margin-bottom: 1.5rem;
  }

  .related-posts__header p {
    margin-top: 0.5rem;
    color: var(--color-text-light);
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .blog-post-layout {
      grid-template-columns: 1fr;
    }

    .blog-post-toc {
      position: static;
      order: -1;
    }
  }

  @media (max-width: 900px) {
    .related-posts__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
