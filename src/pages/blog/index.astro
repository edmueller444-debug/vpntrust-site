---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Блог VPNTrust"
  description="Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры."
>
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{ label: 'Блог' }]} />

      <div class="section-heading">
        <h1 class="mb-3">Блог VPNTrust</h1>
        <p class="text-light">
          Статьи о VPN, обходе блокировок и защите конфиденциальности. Практические инструкции и честные обзоры.
        </p>
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            date={post.data.pubDate.toISOString()}
            category={post.data.category}
          />
        ))}
      </div>

      <div class="cta-box mt-5">
        <h2>Не нашли ответ?</h2>
        <p>Посмотрите наши подробные руководства по VPN для разных устройств и сценариев</p>
        <div class="hero__actions">
          <a href="/best-free-vpn-russia/" class="btn btn-primary">Рейтинг VPN</a>
          <a href="/v2raytun/" class="btn btn-outline">Настройка V2RayTun</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-grid {
    display: grid;
    gap: 1.5rem;
  }

  .mt-5 {
    margin-top: 3rem;
  }

  .cta-box {
    background: #0f172a;
    color: #fff;
    border-radius: 1.5rem;
    padding: 2rem;
  }

  .cta-box h2 {
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cta-box p {
    color: #cbd5e1;
    margin-bottom: 1.25rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero__actions {
      flex-direction: column;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }
</style>
