    flex-shrink: 0;
  }
  
  .step-header h3 {
    margin: 0;
    font-size: 1.0625rem;
  }
  
  .step-content {
    padding: 1.25rem;
  }
  
  .step-content p {
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }
  
  .step-content p:last-child {
    margin-bottom: 0;
  }
  
