---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Контакты' }
];
---

<BaseLayout 
  title="Контакты — Как с нами связаться" 
  description="Telegram, email и другие способы связи. Отвечаем на вопросы, принимаем предложения и исправляем ошибки."
>
  <main class="main-content">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />
      
      <article class="contacts-page">
        <header class="page-header">
          <h1>Контакты</h1>
          <p class="lead">
            Есть вопрос или нашли ошибку? Напишите — постараемся ответить в течение дня.
          </p>
        </header>

        <div class="contacts-grid">
          <div class="contact-card primary">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
            </div>
            <h2>Telegram</h2>
            <p>Быстрее всего отвечаем здесь. Можно задать вопрос или просто подписаться на обновления.</p>
            <a href="https://t.me/topfreevpn" class="contact-link" target="_blank" rel="noopener noreferrer">
              @topfreevpn
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
          </div>

          <div class="contact-card">
            <div class="contact-icon email-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <h2>Email</h2>
            <p>Для подробных вопросов и деловых предложений. Отвечаем в течение суток.</p>
            <a href="mailto:info@vpntrust.ru" class="contact-link">
              info@vpntrust.ru
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
          </div>
        </div>

        <section class="faq-contact">
          <h2>Частые вопросы</h2>
          
          <div class="faq-list">
            <details class="faq-item">
              <summary>Можете помочь с настройкой?</summary>
              <p>
                Мы публикуем подробные инструкции на сайте. Если чего-то не хватает — 
                напишите, и мы добавим нужный материал. Индивидуальную настройку 
                не делаем, но всегда подскажем направление.
              </p>
            </details>

            <details class="faq-item">
              <summary>Размещаете рекламу?</summary>
              <p>
                Рассматриваем предложения от проверенных сервисов, но не обещаем 
                положительный отзыв за деньги. Если продукт плохой — честно об этом напишем.
              </p>
            </details>

            <details class="faq-item">
              <summary>Нашёл ошибку на сайте</summary>
              <p>
                Спасибо! Напишите в Telegram или на почту — исправим. 
                Особенно полезны сообщения о неработающих инструкциях или устаревшей информации.
              </p>
            </details>

            <details class="faq-item">
              <summary>Можно ли заказать обзор сервиса?</summary>
              <p>
                Можно предложить сервис для обзора. Мы протестируем его по нашей методологии 
                и напишем честное мнение. Гарантий на положительную оценку не даём.
              </p>
            </details>
          </div>
        </section>

        <section class="helpful-links">
          <h2>Полезные разделы</h2>
          <div class="links-grid">
            <a href="/best-free-vpn-russia">Рейтинг сервисов</a>
            <a href="/v2raytun">Настройка VLESS</a>
            <a href="/obhod-blokirovok">Способы обхода</a>
            <a href="/blog">Статьи</a>
          </div>
        </section>
      </article>
    </div>
  </main>
</BaseLayout>

<style>
  .main-content {
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .contacts-page {
    background: var(--color-surface);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .page-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .page-header h1 {
    font-size: 2.5rem;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .lead {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .contacts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .contact-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .contact-card.primary {
    background: linear-gradient(135deg, #0088cc, #0077b5);
    border: none;
    color: white;
  }

  .contact-card.primary p {
    color: rgba(255, 255, 255, 0.9);
  }

  .contact-card.primary h2 {
    color: white;
  }

  .contact-icon {
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: white;
  }

  .contact-card:not(.primary) .contact-icon {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  }

  .email-icon {
    background: linear-gradient(135deg, #ea4335, #c5221f) !important;
  }

  .contact-card h2 {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .contact-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .contact-card.primary .contact-link {
    color: white;
  }

  .faq-contact {
    margin-bottom: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .faq-contact h2 {
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-item summary:hover {
    background: var(--color-surface);
  }

  .faq-item summary::marker {
    display: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--color-primary);
    font-weight: 300;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    padding: 0 1.25rem 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .helpful-links {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .helpful-links h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .links-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .links-grid a {
    padding: 0.75rem 1.25rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
  }

  .links-grid a:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .contacts-page {
      padding: 1.5rem;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .contacts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
