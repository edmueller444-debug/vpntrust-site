const siteUrl = 'https://vpntrust.site';

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Лучший бесплатный ВПН 2026 года: рейтинг рабочих сервисов для России',
  description:
    'Независимый рейтинг лучших бесплатных ВПН 2026 года. Обзоры, сравнения, скорость, протоколы и честные отзывы редакции VPNTrust.',
  author: {
    '@type': 'Organization',
    name: 'VPNTrust',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'VPNTrust',
    url: siteUrl,
  },
  datePublished: '2026-04-24',
  dateModified: '2026-04-24',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${siteUrl}/`,
  },
  inLanguage: 'ru-RU',
};

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Лучший бесплатный ВПН 2026',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: services.length,
  itemListElement: services.map((service) => ({
    '@type': 'ListItem',
    position: service.rank,
    item: {
      '@type': 'Product',
      name: service.name,
      description: service.tagline,
      url: service.href,
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: service.score.toFixed(1),
        bestRating: '10',
        ratingCount: '1',
        reviewCount: '1',
      },
    },
