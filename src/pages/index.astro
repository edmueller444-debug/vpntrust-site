---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import Faq from '@/components/Faq.astro';

const features = [
  {
    title: 'Рейтинг сервисов',
    description: 'Сравниваем популярные решения: скорость, надёжность, удобство. Без рекламы и заказных обзоров.',
    href: '/best-free-vpn-russia',
    icon: 'shield'
  },
  {
    title: 'Смартфоны Android',
    description: 'Какие приложения стоит установить и как их правильно настроить.',
    href: '/vpn-dlya-android',
    icon: 'phone'
  },
  {
    title: 'iPhone и iPad',
    description: 'Особенности iOS, доступные приложения в App Store, альтернативные способы.',
    href: '/vpn-dlya-iphone',
    icon: 'phone'
  },
  {
    title: 'Компьютеры Windows',
    description: 'Программы для ПК и ноутбуков. Что выбрать для работы и развлечений.',
    href: '/vpn-dlya-windows',
    icon: 'laptop'
  },
  {
    title: 'Доступ к YouTube',
    description: 'Как избавиться от замедления и смотреть видео в нормальном качестве.',
    href: '/vpn-dlya-youtube',
    icon: 'youtube'
  },
  {
    title: 'Технологии обхода',
    description: 'Разные методы и их особенности. От простых решений до продвинутых.',
    href: '/obhod-blokirovok',
    icon: 'unlock'
  }
];

const faqItems = [
  {
    question: 'Зачем вообще нужен VPN?',
    answer: 'VPN создаёт защищённый канал между вашим устройством и интернетом. Это позволяет обойти региональные ограничения, защитить данные в публичных сетях и сохранить приватность. Провайдер видит только факт подключения к VPN-серверу, но не знает, какие сайты вы посещаете.'
  },
  {
    question: 'Это вообще законно?',
    answer: 'Да. Использование VPN в личных целях не запрещено российским законодательством. Ограничения касаются только операторов VPN-сервисов, которые обязаны подключаться к реестру Роскомнадзора, но не пользователей.'
  },
  {
    question: 'На что смотреть при выборе?',
    answer: 'Зависит от задач. Для обычного сёрфинга подойдёт почти любой. Для стриминга важна скорость. Для конфиденциальности — политика логирования и юрисдикция компании. Для обхода серьёзных блокировок нужны современные протоколы с маскировкой трафика.'
  },
  {
    question: 'Можно ли доверять бесплатным сервисам?',
    answer: 'Некоторым — да. Proton VPN и Windscribe имеют прозрачную бизнес-модель: бесплатные тарифы привлекают пользователей к платным. Но многие бесплатные VPN зарабатывают на продаже данных. Мы рекомендуем только проверенные варианты.'
  },
  {
    question: 'Насколько сильно упадёт скорость?',
    answer: 'С хорошим сервисом и близким сервером — практически незаметно, в пределах 10-15%. Современные протоколы вроде WireGuard работают очень быстро. Заметное падение скорости обычно означает либо перегруженный сервер, либо устаревший протокол.'
  }
];
---

<BaseLayout 
  title="VPN Россия — Помогаем выбрать и настроить" 
  description="Независимые обзоры VPN-сервисов для российских пользователей. Тестируем на практике, даём честные рекомендации, публикуем пошаговые инструкции."
>
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">Разбираемся в VPN вместе с вами</h1>
      <p class="hero-subtitle">
        Тестируем сервисы, сравниваем протоколы, пишем понятные инструкции. 
        Без маркетинговой чепухи — только то, что реально работает.
      </p>
      <div class="hero-actions">
        <a href="/best-free-vpn-russia" class="btn btn-primary">Смотреть рейтинг</a>
        <a href="/obhod-blokirovok" class="btn btn-outline">Способы обхода</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title">С чего начать</h2>
      <p class="section-subtitle">Выберите тему в зависимости от вашего устройства или задачи</p>
      <div class="features-grid">
        {features.map(feature => (
          <FeatureCard {...feature} />
        ))}
      </div>
    </div>
  </section>

  <section class="section how-to-choose">
    <div class="container">
      <h2 class="section-title">Как мы выбираем</h2>
      <div class="criteria-grid">
        <article class="criteria-item">
          <span class="criteria-number">1</span>
          <h3>Задача</h3>
          <p>Для просмотра заблокированных сайтов и для защиты конфиденциальности нужны разные решения. Сначала определяем, что именно нужно.</p>
        </article>
        <article class="criteria-item">
          <span class="criteria-number">2</span>
          <h3>Тестирование</h3>
          <p>Проверяем скорость из России, стабильность соединения, работу с популярными сервисами. Не верим рекламе — проверяем сами.</p>
        </article>
        <article class="criteria-item">
          <span class="criteria-number">3</span>
          <h3>Репутация</h3>
          <p>Изучаем историю компании, политику конфиденциальности, результаты независимых аудитов. Были скандалы — пишем об этом.</p>
        </article>
        <article class="criteria-item">
          <span class="criteria-number">4</span>
          <h3>Практичность</h3>
          <p>Насколько легко установить и использовать. Есть ли нормальная поддержка. Адекватна ли цена для возможностей.</p>
        </article>
      </div>
    </div>
  </section>

  <Faq items={faqItems} />

  <section class="section cta">
    <div class="container">
      <div class="cta-content">
        <h2>Хотите настроить сами?</h2>
        <p>У нас есть подробная инструкция по настройке собственного сервера с VLESS</p>
        <a href="/v2raytun" class="btn btn-primary">Читать инструкцию</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg-alt) 0%, var(--color-bg) 100%);
  }
  
  .hero-title {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    text-wrap: balance;
  }
  
  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto 2rem;
    text-wrap: balance;
  }
  
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  @media (max-width: 768px) {
    .hero {
      padding: 3rem 0;
    }
    
    .hero-title {
      font-size: 2rem;
    }
  }
  
  .section-title {
    text-align: center;
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  
  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 600px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .how-to-choose {
    background: var(--color-bg-alt);
  }
  
  .criteria-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  
  @media (max-width: 900px) {
    .criteria-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 500px) {
    .criteria-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .criteria-item {
    text-align: center;
    padding: 1.5rem;
  }
  
  .criteria-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  
  .criteria-item h3 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }
  
  .criteria-item p {
    font-size: 0.9375rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }
  
  .cta {
    text-align: center;
  }
  
  .cta-content {
    max-width: 500px;
    margin: 0 auto;
  }
  
  .cta-content h2 {
    margin-bottom: 0.5rem;
  }
  
  .cta-content p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }
</style>
