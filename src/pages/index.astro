---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import Faq from '@/components/Faq.astro';

const features = [
  {
    title: 'Рейтинг сервисов',
    description: 'Сравниваем популярные решения: скорость, надёжность, удобство. Без рекламы и заказных обзоров.',
    href: '/best-free-vpn-russia/',
    icon: 'shield'
  },
  {
    title: 'Смартфоны Android',
    description: 'Какие приложения стоит установить и как их правильно настроить.',
    href: '/vpn-dlya-android/',
    icon: 'phone'
  },
  {
    title: 'iPhone и iPad',
    description: 'Особенности iOS, доступные приложения в App Store, альтернативные способы.',
    href: '/vpn-dlya-iphone/',
    icon: 'phone'
  },
  {
    title: 'Компьютеры Windows',
    description: 'Программы для ПК и ноутбуков. Что выбрать для работы и развлечений.',
    href: '/vpn-dlya-windows/',
    icon: 'laptop'
  },
  {
    title: 'Доступ к YouTube',
    description: 'Как избавиться от замедления и смотреть видео в нормальном качестве.',
    href: '/vpn-dlya-youtube/',
    icon: 'youtube'
  },
  {
    title: 'Технологии обхода',
    description: 'Разные методы и их особенности. От простых решений до продвинутых.',
    href: '/obhod-blokirovok/',
    icon: 'unlock'
  }
];

const faqItems = [
  {
    question: 'Зачем вообще нужен VPN?',
    answer: 'VPN создаёт защищённый канал между вашим устройством и интернетом. Это позволяет обойти региональные ограничения, защитить данные в публичных сетях и сохранить приватность. Провайдер видит только факт подключения к VPN-серверу, но не знает, какие сайты вы посещаете.'
  },
  {
    question: 'Это вообще законно?',
    answer: 'Да. Использование VPN в личных целях не запрещено российским законодательством. Ограничения касаются только операторов VPN-сервисов, которые обязаны подключаться к реестру Роскомнадзора, но не пользователей.'
  },
  {
    question: 'На что смотреть при выборе?',
    answer: 'Зависит от задач. Для обычного сёрфинга подойдёт почти любой. Для стриминга важна скорость. Для конфиденциальности — политика логирования и юрисдикция компании. Для обхода серьёзных блокировок нужны современные протоколы с маскировкой трафика.'
  },
  {
    question: 'Можно ли доверять бесплатным сервисам?',
    answer: 'Некоторым — да. Ops VPN, Durev VPN и DedVPN имеют хорошую репутацию в сообществе и зарабатывают на premium-подписках, а не на продаже данных. Мы рекомендуем только проверенные варианты.'
  },
  {
    question: 'Насколько сильно упадёт скорость?',
    answer: 'С хорошим сервисом и близким сервером — практически незаметно, в пределах 10-15%. Современные протоколы вроде WireGuard работают очень быстро. Заметное падение скорости обычно означает либо перегруженный сервер, либо устаревший протокол.'
  }
];
---

<BaseLayout
  title="VPNTrust — честно о VPN, обходе блокировок и конфиденциальности"
  description="Тестируем VPN-сервисы, сравниваем протоколы и делаем понятные инструкции для пользователей из России."
>
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-sky-50 via-white to-emerald-50"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-20 sm:px-8 lg:px-12 lg:py-28">
      <div class="max-w-3xl">
        <span class="mb-6 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-1.5 text-sm font-medium text-sky-700 shadow-sm">
          Честные обзоры и инструкции
        </span>
        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          Разбираемся в VPN вместе с вами
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          Тестируем сервисы, сравниваем протоколы, пишем понятные инструкции. Без маркетинговой чепухи — только то, что реально работает.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="/best-free-vpn-russia/"
            class="inline-flex items-center justify-center rounded-2xl bg-sky-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-sky-700"
          >
            Смотреть рейтинг
          </a>
          <a
            href="/obhod-blokirovok/"
            class="inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-6 py-3 text-base font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
          >
            Способы обхода
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16 sm:px-8 lg:px-12">
    <div class="mb-10 max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">С чего начать</h2>
      <p class="mt-4 text-lg text-slate-600">
        Выберите тему в зависимости от вашего устройства или задачи
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <FeatureCard {...feature} />
      ))}
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-6 py-16 sm:px-8 lg:px-12">
      <div class="mb-10 max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Как мы выбираем</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="mb-4 text-sm font-semibold text-sky-600">1</div>
          <h3 class="text-xl font-semibold text-slate-900">Задача</h3>
          <p class="mt-3 text-slate-600">
            Для просмотра заблокированных сайтов и для защиты конфиденциальности нужны разные решения. Сначала определяем, что именно нужно.
          </p>
        </div>

        <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="mb-4 text-sm font-semibold text-sky-600">2</div>
          <h3 class="text-xl font-semibold text-slate-900">Тестирование</h3>
          <p class="mt-3 text-slate-600">
            Проверяем скорость из России, стабильность соединения, работу с популярными сервисами. Не верим рекламе — проверяем сами.
          </p>
        </div>

        <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="mb-4 text-sm font-semibold text-sky-600">3</div>
          <h3 class="text-xl font-semibold text-slate-900">Репутация</h3>
          <p class="mt-3 text-slate-600">
            Изучаем историю компании, политику конфиденциальности, результаты независимых аудитов. Были скандалы — пишем об этом.
          </p>
        </div>

        <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="mb-4 text-sm font-semibold text-sky-600">4</div>
          <h3 class="text-xl font-semibold text-slate-900">Практичность</h3>
          <p class="mt-3 text-slate-600">
            Насколько легко установить и использовать. Есть ли нормальная поддержка. Адекватна ли цена для возможностей.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-16 sm:px-8 lg:px-12">
    <div class="rounded-3xl bg-slate-900 px-8 py-10 text-white">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Хотите настроить сами?</h2>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">
        У нас есть подробная инструкция по настройке собственного сервера с VLESS
      </p>
      <div class="mt-8">
        <a
          href="/vless-server/"
          class="inline-flex items-center justify-center rounded-2xl bg-white px-6 py-3 text-base font-semibold text-slate-900 transition hover:bg-slate-100"
        >
          Читать инструкцию
        </a>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-4xl px-6 py-16 sm:px-8 lg:px-12">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Частые вопросы</h2>
      <div class="mt-8">
        <Faq items={faqItems} />
      </div>
    </div>
  </section>
</BaseLayout>
