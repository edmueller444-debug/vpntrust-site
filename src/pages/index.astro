  {
    title: 'Устойчивость к DPI',
    description:
      'Тестировали соединение там, где провайдер активно вмешивается в трафик и режет обычный OpenVPN.',
  },
  {
    title: 'Часы пик',
    description:
      'Замеры с 20:00 до 23:00 по Москве — в это время падает всё, что не готово к высокой нагрузке.',
  },
  {
    title: 'Скорость загрузки',
    description:
      'Speedtest и fast.com на трёх локациях сервиса, если локации доступны.',
  },
  {
    title: 'Прозрачность',
    description:
      'Сервис должен открыто рассказывать, что входит в бесплатный доступ и за что нужно платить.',
  },
  {
    title: 'Удобство старта',
    description:
      'Новичок должен получить рабочий ключ не более чем за 3 минуты.',
  },
  {
    title: 'Ответственность команды',
    description:
      'Живая поддержка в чате или боте, реакция на обращения.',
  },
];

const scenarios = [
  { title: 'Нужен ВПН прямо сейчас и без настроек', service: 'Ops VPN' },
  { title: 'Нужен стабильный сервис с сайтом и кабинетом', service: 'Durev VPN' },
  { title: 'Основной сценарий — YouTube и стриминги', service: 'Дед VPN' },
  { title: 'Провайдер ввёл белый список', service: 'Sota VPN' },
  { title: 'VPN нужен в первую очередь на смартфоне', service: 'Hit VPN' },
];

const howToSteps = [
  {
    title: 'Перейдите на сайт или в Telegram-бота сервиса',
    description: 'Выберите любой вариант из нашего рейтинга и откройте его страницу или бота.',
  },
  {
    title: 'Получите ключ',
    description: 'В ботах — нажатием кнопки, на сайтах — после регистрации в личном кабинете.',
  },
  {
    title: 'Установите клиент',
    description:
      'На iPhone и Android используйте V2RayTun или Hiddify, на Windows и macOS подойдёт Hiddify или NekoBox, на Linux — sing-box.',
  },
  {
    title: 'Импортируйте ключ',
    description:
      'Скопируйте строку с конфигурацией и вставьте в клиент через кнопку «Добавить из буфера» или отсканируйте QR-код.',
  },
  {
    title: 'Включите соединение',
    description: 'Один тап по переключателю — и вы в зашифрованном туннеле.',
  },
];

