---
import BaseLayout from '@/layouts/BaseLayout.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import Faq from '@/components/Faq.astro';

const features = [
  {
    title: 'Рейтинг сервисов',
    description: 'Сравниваем популярные решения: скорость, надёжность, удобство. Без рекламы и заказных обзоров.',
    href: '/best-free-vpn-russia/',
    icon: 'shield'
  },
  {
    title: 'Смартфоны Android',
    description: 'Какие приложения стоит установить и как их правильно настроить.',
    href: '/vpn-dlya-android/',
    icon: 'phone'
  },
  {
    title: 'iPhone и iPad',
    description: 'Особенности iOS, доступные приложения в App Store, альтернативные способы.',
    href: '/vpn-dlya-iphone/',
    icon: 'phone'
  },
  {
    title: 'Компьютеры Windows',
    description: 'Программы для ПК и ноутбуков. Что выбрать для работы и развлечений.',
    href: '/vpn-dlya-windows/',
    icon: 'laptop'
  },
  {
    title: 'Доступ к YouTube',
    description: 'Как избавиться от замедления и смотреть видео в нормальном качестве.',
    href: '/vpn-dlya-youtube/',
    icon: 'youtube'
  },
  {
    title: 'Технологии обхода',
    description: 'Разные методы и их особенности. От простых решений до продвинутых.',
    href: '/obhod-blokirovok/',
    icon: 'unlock'
  }
];

const faqItems = [
  {
    question: 'Зачем вообще нужен VPN?',
    answer: 'VPN создаёт защищённый канал между вашим устройством и интернетом. Это позволяет обойти региональные ограничения, защитить данные в публичных сетях и сохранить приватность. Провайдер видит только факт подключения к VPN-серверу, но не знает, какие сайты вы посещаете.'
  },
  {
    question: 'Это вообще законно?',
    answer: 'Да. Использование VPN в личных целях не запрещено российским законодательством. Ограничения касаются только операторов VPN-сервисов, которые обязаны подключаться к реестру Роскомнадзора, но не пользователей.'
  },
  {
    question: 'На что смотреть при выборе?',
    answer: 'Зависит от задач. Для обычного сёрфинга подойдёт почти любой. Для стриминга важна скорость. Для конфиденциальности — политика логирования и юрисдикция компании. Для обхода серьёзных блокировок нужны современные протоколы с маскировкой трафика.'
  },
  {
    question: 'Можно ли доверять бесплатным сервисам?',
    answer: 'Некоторым — да. Ops VPN, Durev VPN и DedVPN имеют хорошую репутацию в сообществе и зарабатывают на premium-подписках, а не на продаже данных. Мы рекомендуем только проверенные варианты.'
  },
  {
    question: 'Насколько сильно упадёт скорость?',
    answer: 'С хорошим сервисом и близким сервером — практически незаметно, в пределах 10-15%. Современные протоколы вроде WireGuard работают очень быстро. Заметное падение скорости обычно означает либо перегруженный сервер, либо устаревший протокол.'
  }
];
---

<BaseLayout
  title="VPNTrust — честно о VPN, обходе блокировок и конфиденциальности"
  description="Тестируем VPN-сервисы, сравниваем протоколы и делаем понятные инструкции для пользователей из России."
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__badge">Честные обзоры и инструкции</div>
      <h1 class="hero__title">Разбираемся в VPN вместе с вами</h1>
      <p class="hero__text">
        Тестируем сервисы, сравниваем протоколы, пишем понятные инструкции. Без маркетинговой чепухи — только то, что реально работает.
      </p>

      <div class="hero__actions">
        <a href="/best-free-vpn-russia/" class="btn btn-primary">Смотреть рейтинг</a>
        <a href="/obhod-blokirovok/" class="btn btn-outline">Способы обхода</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <h2 class="mb-2">С чего начать</h2>
        <p class="text-light">Выберите тему в зависимости от вашего устройства или задачи</p>
      </div>

      <div class="features-grid">
        {features.map((feature) => (
          <FeatureCard {...feature} />
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-heading">
        <h2 class="mb-3">Как мы выбираем</h2>
      </div>

      <div class="steps-grid">
        <div class="step-card">
          <div class="step-card__num">1</div>
          <h3>Задача</h3>
          <p>
            Для просмотра заблокированных сайтов и для защиты конфиденциальности нужны разные решения. Сначала определяем, что именно нужно.
          </p>
        </div>

        <div class="step-card">
          <div class="step-card__num">2</div>
          <h3>Тестирование</h3>
          <p>
            Проверяем скорость из России, стабильность соединения, работу с популярными сервисами. Не верим рекламе — проверяем сами.
          </p>
        </div>

        <div class="step-card">
          <div class="step-card__num">3</div>
          <h3>Репутация</h3>
          <p>
            Изучаем историю компании, политику конфиденциальности, результаты независимых аудитов. Были скандалы — пишем об этом.
          </p>
        </div>

        <div class="step-card">
          <div class="step-card__num">4</div>
          <h3>Практичность</h3>
          <p>
            Насколько легко установить и использовать. Есть ли нормальная поддержка. Адекватна ли цена для возможностей.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2>Хотите настроить сами?</h2>
        <p>У нас есть подробная инструкция по настройке собственного сервера с VLESS</p>
        <a href="/v2raytun/" class="btn cta-box__button">Читать инструкцию</a>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container faq-wrap">
      <h2 class="mb-3">Частые вопросы</h2>
      <Faq items={faqItems} />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, #f0f9ff 0%, #ffffff 55%, #ecfdf5 100%);
    padding: 4rem 0 5rem;
  }

  .hero__inner {
    max-width: 900px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border: 1px solid #bfdbfe;
    border-radius: 999px;
    background: #ffffff;
    color: #1d4ed8;
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
  }

  .hero__title {
    font-size: 3.25rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #0f172a;
  }

  .hero__text {
    max-width: 760px;
    font-size: 1.25rem;
    color: #475569;
    margin-bottom: 2rem;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-alt {
    background: var(--color-bg-alt);
  }

  .section-heading {
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.25rem;
    padding: 1.5rem;
  }

  .step-card__num {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #dbeafe;
    color: #1d4ed8;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .step-card h3 {
    margin-bottom: 0.75rem;
  }

  .step-card p {
    color: var(--color-text-light);
  }

  .cta-box {
    background: #0f172a;
    color: #fff;
    border-radius: 1.5rem;
    padding: 2.5rem;
  }

  .cta-box h2 {
    color: #fff;
    margin-bottom: 1rem;
  }

  .cta-box p {
    color: #cbd5e1;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }

  .cta-box__button {
    background: #fff;
    color: #0f172a;
  }

  .cta-box__button:hover {
    color: #0f172a;
    background: #f8fafc;
  }

  .faq-wrap {
    max-width: 900px;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .steps-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero__title {
      font-size: 2.6rem;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2.5rem 0 3rem;
    }

    .hero__title {
      font-size: 2.1rem;
    }

    .hero__text {
      font-size: 1.05rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__actions .btn {
      width: 100%;
    }

    .features-grid,
    .steps-grid {
      grid-template-columns: 1fr;
    }

    .cta-box {
      padding: 1.5rem;
    }
  }
</style>
