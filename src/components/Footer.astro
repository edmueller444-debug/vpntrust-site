---
const deviceLinks = [
  { href: '/vpn-dlya-android/', label: 'VPN для Android' },
  { href: '/vpn-dlya-iphone/', label: 'VPN для iPhone' },
  { href: '/vpn-dlya-windows/', label: 'VPN для Windows' },
];

const useCaseLinks = [
  { href: '/vpn-dlya-youtube/', label: 'VPN для YouTube' },
  { href: '/vpn-dlya-discord/', label: 'VPN для Discord' },
  { href: '/telegram-ne-rabotaet/', label: 'Telegram не работает' },
];

const infoLinks = [
  { href: '/best-free-vpn-russia/', label: 'Лучшие VPN' },
  { href: '/obhod-blokirovok/', label: 'Обход белых списков' },
  { href: '/v2raytun/', label: 'V2RayTun' },
  { href: '/blog/', label: 'Блог' },
  { href: '/o-nas/', label: 'О проекте' },
  { href: '/kontakty/', label: 'Контакты' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-logo">VPNTrust</a>
      <p>
        Помогаем выбрать работающий VPN и обойти блокировки в России. Честные обзоры и практические инструкции.
      </p>
    </div>

    <div>
      <h3>По устройствам</h3>
      <ul class="footer-list">
        {deviceLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3>Применение</h3>
      <ul class="footer-list">
        {useCaseLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3>Информация</h3>
      <ul class="footer-list">
        {infoLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      © {currentYear} VPNTrust. Все материалы носят информационный характер.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    background: #ffffff;
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
    gap: 2rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .footer-logo {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .footer-brand p {
    color: var(--color-text-light);
    max-width: 320px;
  }

  .site-footer h3 {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .footer-list {
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .footer-list a {
    color: var(--color-text-light);
  }

  .footer-list a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 0;
    color: var(--color-text-light);
    font-size: 0.95rem;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .footer-brand p {
      max-width: none;
    }
  }
</style>
