---
const deviceLinks = [
  { href: '/vpn-dlya-android/', label: 'VPN для Android' },
  { href: '/vpn-dlya-iphone/', label: 'VPN для iPhone' },
  { href: '/vpn-dlya-windows/', label: 'VPN для Windows' },
];

const useCaseLinks = [
  { href: '/vpn-dlya-youtube/', label: 'VPN для YouTube' },
  { href: '/vpn-dlya-discord/', label: 'VPN для Discord' },
  { href: '/telegram-ne-rabotaet/', label: 'Telegram не работает' },
];

const infoLinks = [
  { href: '/best-free-vpn-russia/', label: 'Лучшие VPN' },
  { href: '/obhod-blokirovok/', label: 'Обход белых списков' },
  { href: '/v2raytun/', label: 'V2RayTun' },
  { href: '/blog/', label: 'Блог' },
  { href: '/o-nas/', label: 'О проекте' },
  { href: '/kontakty/', label: 'Контакты' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 sm:px-8 lg:grid-cols-[1.2fr_1fr_1fr_1fr] lg:px-12">
    <div>
      <a href="/" class="text-xl font-bold tracking-tight text-slate-900">VPNTrust</a>
      <p class="mt-4 max-w-sm text-slate-600">
        Помогаем выбрать работающий VPN и обойти блокировки в России. Честные обзоры и практические инструкции.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">По устройствам</h3>
      <ul class="mt-4 space-y-3">
        {deviceLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-600 transition hover:text-sky-700">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">Применение</h3>
      <ul class="mt-4 space-y-3">
        {useCaseLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-600 transition hover:text-sky-700">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">Информация</h3>
      <ul class="mt-4 space-y-3">
        {infoLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-600 transition hover:text-sky-700">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="mx-auto max-w-6xl px-6 py-6 text-sm text-slate-500 sm:px-8 lg:px-12">
      © {currentYear} VPNTrust. Все материалы носят информационный характер.
    </div>
  </div>
</footer>
