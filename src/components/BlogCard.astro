---
export interface Props {
  title: string;
  description: string;
  slug: string;
  date: string;
  category: string;
}

const { title, description, slug, date, category } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("ru-RU", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
---

<article class="blog-card">
  <a href={`/blog/${slug}/`} class="blog-card__link">
    <div class="blog-card__meta">
      <span class="blog-card__category">{category}</span>
      <span class="blog-card__dot">•</span>
      <time datetime={date}>{formattedDate}</time>
    </div>

    <h2 class="blog-card__title">{title}</h2>
    <p class="blog-card__description">{description}</p>

    <div class="blog-card__footer">
      <span class="blog-card__cta">Читать статью</span>
      <span class="blog-card__arrow" aria-hidden="true">→</span>
    </div>
  </a>
</article>

<style>
  .blog-card {
    height: 100%;
  }

  .blog-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .blog-card__link:hover {
    transform: translateY(-4px);
    border-color: rgba(37, 99, 235, 0.25);
    box-shadow: 0 18px 40px rgba(37, 99, 235, 0.08);
    color: inherit;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .blog-card__category {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(37, 99, 235, 0.08);
    color: var(--color-primary);
    font-weight: 600;
    line-height: 1;
  }

  .blog-card__dot {
    opacity: 0.5;
  }

  .blog-card__title {
    margin-bottom: 0.75rem;
    font-size: 1.35rem;
    line-height: 1.35;
  }

  .blog-card__description {
    margin: 0;
    color: var(--color-text-light);
    line-height: 1.65;
  }

  .blog-card__footer {
    margin-top: auto;
    padding-top: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--color-primary);
    font-weight: 600;
  }

  .blog-card__arrow {
    transition: transform 0.2s ease;
  }

  .blog-card__link:hover .blog-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-card__link {
      padding: 1.25rem;
      border-radius: 0.875rem;
    }

    .blog-card__title {
      font-size: 1.2rem;
    }
  }
</style>
