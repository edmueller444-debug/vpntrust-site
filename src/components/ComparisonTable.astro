---
export interface VpnItem {
  name: string;
  speed: string;
  devices: string;
  servers: string;
  price: string;
  rating: number;
  pros: string[];
  cons: string[];
  link?: string;
}

export interface Props {
  items: VpnItem[];
}

const { items } = Astro.props;

function getRatingStars(rating: number): string {
  return '★'.repeat(rating) + '☆'.repeat(5 - rating);
}
---

<div class="comparison-wrapper">
  <table class="comparison-table">
    <thead>
      <tr>
        <th>VPN-сервис</th>
        <th>Скорость</th>
        <th>Устройства</th>
        <th>Серверы</th>
        <th>Цена</th>
        <th>Оценка</th>
        <th>Скачать</th>
      </tr>
    </thead>
    <tbody>
      {items.map((item, index) => (
        <tr>
          <td class="vpn-name">
            <span class="vpn-rank">#{index + 1}</span>
            <strong>{item.name}</strong>
          </td>
          <td>{item.speed}</td>
          <td>{item.devices}</td>
          <td>{item.servers}</td>
          <td>{item.price}</td>
          <td class="vpn-rating" title={`Оценка: ${item.rating} из 5`}>
            <span class="stars">{getRatingStars(item.rating)}</span>
          </td>
          <td class="vpn-action">
            {item.link ? (
              <a href={item.link} class="download-btn" target="_blank" rel="noopener">Скачать VPN</a>
            ) : (
              <span class="no-link">—</span>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<div class="comparison-cards">
  {items.map((item, index) => (
    <article class="vpn-card">
      <header class="vpn-card-header">
        <span class="vpn-rank">#{index + 1}</span>
        <h3>{item.name}</h3>
        <span class="stars" title={`Оценка: ${item.rating} из 5`}>{getRatingStars(item.rating)}</span>
      </header>
      <div class="vpn-card-stats">
        <div class="stat">
          <span class="stat-label">Скорость</span>
          <span class="stat-value">{item.speed}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Устройства</span>
          <span class="stat-value">{item.devices}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Серверы</span>
          <span class="stat-value">{item.servers}</span>
        </div>
        <div class="stat">
          <span class="stat-label">Цена</span>
          <span class="stat-value">{item.price}</span>
        </div>
      </div>
      <div class="vpn-card-details">
        <div class="pros">
          <strong>Плюсы:</strong>
          <ul>
            {item.pros.map(pro => <li>{pro}</li>)}
          </ul>
        </div>
        <div class="cons">
          <strong>Минусы:</strong>
          <ul>
            {item.cons.map(con => <li>{con}</li>)}
          </ul>
        </div>
      </div>
      {item.link && (
        <div class="vpn-card-action">
          <a href={item.link} class="download-btn" target="_blank" rel="noopener">Скачать VPN</a>
        </div>
      )}
    </article>
  ))}
</div>

<style>
  .comparison-wrapper {
    overflow-x: auto;
  }
  
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }
  
  .comparison-table th,
  .comparison-table td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  
  .comparison-table th {
    background: var(--color-bg-alt);
    font-weight: 600;
    white-space: nowrap;
  }
  
  .comparison-table tr:hover {
    background: var(--color-bg-alt);
  }
  
  .vpn-name {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  
  .vpn-rank {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  
  .stars {
    color: var(--color-warning);
    letter-spacing: 1px;
  }
  
  .vpn-action {
    text-align: center;
  }
  
  .download-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }
  
  .download-btn:hover {
    background: var(--color-primary-dark, #1d4ed8);
    color: #fff;
  }
  
  .no-link {
    color: var(--color-text-light);
  }
  
  .comparison-cards {
    display: none;
  }
  
  @media (max-width: 900px) {
    .comparison-wrapper {
      display: none;
    }
    
    .comparison-cards {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
  }
  
  .vpn-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  
  .vpn-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-bg-alt);
  }
  
  .vpn-card-header h3 {
    flex: 1;
    font-size: 1.125rem;
    margin: 0;
  }
  
  .vpn-card-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .stat-label {
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .stat-value {
    font-weight: 500;
  }
  
  .vpn-card-details {
    padding: 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--color-border);
  }
  
  .vpn-card-details ul {
    margin-top: 0.5rem;
    padding-left: 1.25rem;
  }
  
  .vpn-card-details li {
    margin-bottom: 0.25rem;
  }
  
  .pros {
    color: var(--color-success);
  }
  
  .pros strong {
    color: var(--color-text);
  }
  
  .cons {
    color: #dc2626;
  }
  
  .cons strong {
    color: var(--color-text);
  }
  
  .vpn-card-action {
    padding: 1rem;
    text-align: center;
  }
  
  .vpn-card-action .download-btn {
    width: 100%;
    padding: 0.75rem 1rem;
  }
</style>
